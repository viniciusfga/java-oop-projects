classDiagram
direction LR

    class Pessoa {
        <<abstract>>
        -int id
        -String nome
        -String telefone
        -String email
    }

    class Aluno {
        -String matricula
    }

    class Professor {
        -String siape

    }

    class Curso {
        -int id
        -String nome
        -String codigo
        -String descricao
    }

    class Disciplina {
        -int id
        -String codigo
        -String nome
        -int cargaHoraria
        -String ementa
        -Modalidade modalidade
    }

    class Turma {
        -int id
        -String codigo
        -String nome
    }

    class PeriodoLetivo {
        -int ano
        -int semestre
    }

    class Matricula {
        -Date dataMatricula
        -SituacaoMatricula situacao
        -double notaFinal
    }

    class Modalidade {
        <<enumeration>>
        PRESENCIAL
        EAD
        HIBRIDO
    }

    class SituacaoMatricula {
        <<enumeration>>
        ATIVA
        TRANCADA
        CANCELADA
        CONCLUIDA
        REPROVADA
    }

    %% HERANÇA
    Pessoa <|-- Aluno : é um
    Pessoa <|-- Professor : é um

    %% RELACIONAMENTOS
    Curso "1" -- "*" Disciplina : possui

    Disciplina "1" -- "*" Turma : oferta

    Turma "*" -- "1" PeriodoLetivo
    Professor "1" -- "*" Turma : ministra

    Aluno "1" -- "*" Matricula : possui
    Turma "1" -- "*" Matricula : contém